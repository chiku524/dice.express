{
  "name": "dice-express",
  "version": "1.0.21",
  "description": "dice.express — prediction markets with Pips on Cloudflare",
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.21.0"
  },
  "scripts": {
    "start": "npm run start:frontend",
    "start:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:frontend:tauri": "node scripts/build-frontend-for-tauri.mjs",
    "pages:dev": "npm run build:frontend && npx wrangler pages dev frontend/dist",
    "pages:project:create": "bash scripts/cloudflare-setup.sh",
    "pages:deploy": "npm run build:frontend && npx wrangler pages deploy frontend/dist --project-name=dice-express",
    "pages:setup": "npm run pages:project:create && npm run pages:deploy",
    "pages:custom-domain": "bash scripts/pages-add-custom-domain.sh",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:signer-generate": "tauri signer generate"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  },
  "keywords": [
    "prediction-markets",
    "virtual-currency",
    "cloudflare"
  ],
  "author": "",
  "license": "MIT"
}
