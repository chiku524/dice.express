module TestContract where

-- Simple test contract to verify SDK and deployment work
template HelloWorld
  with
    owner : Party
    message : Text
    createdAt : Time
  where
    signatory owner

    choice SayHello : Text
      controller owner
      do
        return message

    choice UpdateMessage : ContractId HelloWorld
      with
        newMessage : Text
      controller owner
      do
        create this with message = newMessage

