{
  "productName": "dice.express",
  "version": "1.0.6",
  "identifier": "express.dice.app",
  "build": {
    "beforeDevCommand": "npm run start:frontend",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "dice.express",
        "url": "/launch",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "visible": false,
        "decorations": true
      },
      {
        "label": "splashscreen",
        "title": "dice.express",
        "url": "/splashscreen",
        "width": 420,
        "height": 320,
        "resizable": false,
        "center": true,
        "visible": true,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": null
    },
    "longDescription": "",
    "shortDescription": "",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "category": "Finance"
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
