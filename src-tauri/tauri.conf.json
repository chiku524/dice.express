{
  "productName": "dice.express",
  "version": "1.0.27",
  "identifier": "com.dice.express",
  "build": {
    "beforeDevCommand": "npm run start:frontend",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:frontend:tauri",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "dice.express",
        "url": "/launch",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "visible": false,
        "decorations": true
      },
      {
        "label": "splashscreen",
        "title": "dice.express",
        "url": "/splashscreen",
        "width": 420,
        "height": 320,
        "resizable": false,
        "center": true,
        "visible": true,
        "decorations": false,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": null
    },
    "longDescription": "",
    "shortDescription": "",
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "category": "Finance"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCODY2OTY4Rjg2MUI2NDgKUldSSXRtSDRhR21HNjdLZGZqb0VkWXJJOUY0SHRGS1Z1NWR6cDMyTkU0bXZWTDVGRGY3QVBCYkUK",
      "endpoints": [
        "https://github.com/chiku524/dice.express/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
